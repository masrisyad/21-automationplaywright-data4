# Login target
LOGIN_URL=https://example.com/login
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# Browser/test settings
HEADLESS=false
TIMEOUT_MS=10000
WAIT_AFTER_LOGIN_SECONDS=3
WAIT_AFTER_ACTION_SECONDS=3

# Kelasku test data
KELASKU_INFO_TEXT=Test 2
KELASKU_EDIT_INFO_TEXT=Test Edit

# Email report settings
SEND_EMAIL=false
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
EMAIL_SENDER=automation@example.com
EMAIL_SENDER_NAME=Automation Test
EMAIL_RECIPIENT=recipient@example.com
EMAIL_RECIPIENT_NAME=Recipient
EMAIL_SUBJECT=Automation Test Report
EMAIL_BODY=Attached automation test report.
